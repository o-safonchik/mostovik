// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model Project {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  previewImage    String   @map("preview_image")
  finished        Boolean  @default(false) 
  customer        String
  workType        String   @map("work_type")
  startYear       Int      @map("start_year")
  endYear         Int?     @map("end_year")
  description     String
  stages          String[]
  stagesImage     String   @map("stages_image")
  tags            String[]
  characteristics Json
  charactImage    String   @map("charact_image")
  expertResults   String[] @map("expert_results")
  locationName    String   @map("location_name")
  latitude        Float
  longitude       Float
  metaTitle       String   @map("meta_title")
  metaDescription String   @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")

  news News[]

  @@map("projects")
}

model News {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  slug            String    @unique
  publishDate     DateTime  @map("publish_date")
  previewImage    String    @map("preview_image")
  content         String
  metaTitle       String    @map("meta_title")
  metaDescription String    @map("meta_description")
  createdAt       DateTime  @default(now()) @map("created_at")

  projectId String?  @map("project_id") @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("news")
}

model Vacancy {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  experience      String
  salary          Int
  employment      String
  responsibilities String
  requirements     String
  skills          String[]
  advantages      String
  publishDate     DateTime @map("publish_date")
  metaTitle       String   @map("meta_title")
  metaDescription String   @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")

  applications Application[]

  @@map("vacancies")
}

model Application {
  id         String   @id @default(uuid()) @db.Uuid
  surname    String
  name       String
  phone      String
  email      String
  resume     String
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  vacancyId String  @map("vacancy_id") @db.Uuid
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@map("applications")
}